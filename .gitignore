# Scan outputs
*.json
*.csv
*.html
!docs/*.html
!gitexpose/data/*.json
!tests/fixtures/*.json
!tests/fixtures/synthetic_repo/**/*.json
!tests/fixtures/synthetic_repo/.continue/
# v0.3 smoke fixture: the generic `.env` rule (above) would drop this tracked
# test fixture, which is exactly the bug that left test_smoke_v03 red on clean
# checkouts. Negate it so the fixture stays in version control.
!tests/fixtures/synthetic_repo_v03/.env
# v0.5 lock-file fixtures: `package-lock.json` etc. are dropped by JS-tooling
# gitignore rules; negate the SCA fixture dir so parser tests pass on clean checkouts.
!tests/fixtures/lockfiles/
!tests/fixtures/lockfiles/**

# Git dumps
git-dumps/
dumps/
extracted/

# Temp files
*.tmp
*.temp
*.log

# Archived files
move_git/

